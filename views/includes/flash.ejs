
<div class="flash-panel">
  <% if (Array.isArray(success) && success.length) { %>
    <% success.forEach(function(msg) { %>
      <div class="flash-card flash-card--success">
        <button type="button" class="flash-close" aria-label="Close flash message">×</button>
        <div class="flash-icon flash-icon--success">✓</div>
        <div class="flash-body">
          <p class="flash-title">Success</p>
          <p class="flash-message"><%= msg %></p>
        </div>
      </div>
    <% }); %>
  <% } %>

  <% if (Array.isArray(error) && error.length) { %>
    <% error.forEach(function(msg) { %>
      <div class="flash-card flash-card--error">
        <button type="button" class="flash-close" aria-label="Close flash message">×</button>
        <div class="flash-icon flash-icon--error">!</div>
        <div class="flash-body">
          <p class="flash-title">Error</p>
          <p class="flash-message"><%= msg %></p>
        </div>
      </div>
    <% }); %>
  <% } %>
</div>
<script>
  document.addEventListener('click', function(event) {
    if (!event.target.closest('.flash-close')) return;
    const card = event.target.closest('.flash-card');
    if (!card) return;
    card.classList.add('flash-card-hidden');
    card.addEventListener('animationend', function() {
      card.remove();
    }, { once: true });
  });
</script>


























